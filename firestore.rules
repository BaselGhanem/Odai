rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function profile() { return get(userPath()).data; }
    function active() { return signedIn() && exists(userPath()) && profile().active == true && profile().isDeleted == false; }
    function admin() { return active() && profile().role == 'admin'; }
    function has(module, action) { return admin() || (active() && profile().permissions[module] is list && action in profile().permissions[module]); }
    function bootstrapMissing() { return !exists(/databases/$(database)/documents/settings/bootstrap); }
    function ownsMetadata() { return request.resource.data.createdBy == request.auth.uid; }

    match /settings/bootstrap {
      allow read: if true;
      allow create: if signedIn() && bootstrapMissing() && request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if false;
    }
    match /users/{uid} {
      allow create: if signedIn() && uid == request.auth.uid && bootstrapMissing()
                    && request.resource.data.role == 'admin'
                    && getAfter(/databases/$(database)/documents/settings/bootstrap).data.adminUid == uid;
      allow read: if active() && (admin() || uid == request.auth.uid);
      allow update: if admin() || (active() && uid == request.auth.uid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.permissions == resource.data.permissions
                    && request.resource.data.active == resource.data.active);
      allow delete: if false;
    }
    match /settings/{id} {
      allow read: if active();
      allow create: if (signedIn() && bootstrapMissing()) || admin();
      allow update: if has('settings', 'edit');
      allow delete: if false;
    }
    match /products/{id} { allow read: if has('products','view') || has('pos','view') || has('purchases','view') || has('rentals','view'); allow create: if has('products','create') && ownsMetadata(); allow update: if has('products','edit') || has('pos','create') || has('purchases','create') || has('rentals','create') || has('invoices','void'); allow delete: if false; }
    match /services/{id} { allow read: if has('services','view') || has('pos','view'); allow create: if has('services','create') && ownsMetadata(); allow update: if has('services','edit'); allow delete: if false; }
    match /customers/{id} { allow read: if has('customers','view') || has('pos','view') || has('rentals','view'); allow create: if has('customers','create') && ownsMetadata(); allow update: if has('customers','edit') || has('pos','create') || has('invoices','void'); allow delete: if false; }
    match /suppliers/{id} { allow read: if has('suppliers','view') || has('purchases','view'); allow create: if has('suppliers','create') && ownsMetadata(); allow update: if has('suppliers','edit') || has('purchases','create'); allow delete: if false; }
    match /employees/{id} { allow read: if has('employees','view') || has('salaries','view') || has('advances','view'); allow create: if has('employees','create') && ownsMetadata(); allow update: if has('employees','edit'); allow delete: if false; }
    match /sales/{id} { allow read: if has('invoices','view') || has('reports','view') || has('dashboard','view'); allow create: if has('pos','create') && ownsMetadata(); allow update: if has('invoices','edit') || has('invoices','void'); allow delete: if false; }
    match /saleItems/{id} { allow read: if has('invoices','view') || has('reports','view'); allow create: if has('pos','create') && ownsMetadata(); allow update, delete: if false; }
    match /purchases/{id} { allow read: if has('purchases','view') || has('reports','view') || has('dashboard','view'); allow create: if has('purchases','create') && ownsMetadata(); allow update: if has('purchases','edit'); allow delete: if false; }
    match /purchaseItems/{id} { allow read: if has('purchases','view') || has('reports','view'); allow create: if has('purchases','create') && ownsMetadata(); allow update, delete: if false; }
    match /rentals/{id} { allow read: if has('rentals','view') || has('reports','view') || has('dashboard','view'); allow create: if has('rentals','create') && ownsMetadata(); allow update: if has('rentals','edit') || has('rentals','create'); allow delete: if false; }
    match /expenses/{id} { allow read: if has('expenses','view') || has('reports','view') || has('dashboard','view'); allow create: if has('expenses','create') && ownsMetadata(); allow update: if has('expenses','edit'); allow delete: if false; }
    match /salaries/{id} { allow read: if has('salaries','view') || has('reports','view'); allow create: if has('salaries','create') && ownsMetadata(); allow update: if has('salaries','edit'); allow delete: if false; }
    match /advances/{id} { allow read: if has('advances','view') || has('reports','view'); allow create: if has('advances','create') && ownsMetadata(); allow update: if has('advances','edit'); allow delete: if false; }
    match /stockMovements/{id} { allow read: if has('products','view') || has('reports','view'); allow create: if active() && ownsMetadata(); allow update, delete: if false; }
    match /cashMovements/{id} { allow read: if has('reports','view'); allow create: if active() && ownsMetadata(); allow update, delete: if false; }
    match /auditLogs/{id} { allow read: if has('auditLogs','view'); allow create: if active() && ownsMetadata(); allow update, delete: if false; }
    match /offers/{id} { allow read: if active(); allow create: if has('offers','create') && ownsMetadata(); allow update: if has('offers','edit'); allow delete: if false; }
    match /dailyClosings/{id} { allow read: if has('dailyClosings','view') || has('reports','view'); allow create: if has('dailyClosings','create') && ownsMetadata(); allow update: if has('dailyClosings','edit'); allow delete: if false; }
    match /patchTypes/{id} { allow read: if active(); allow create: if (signedIn() && bootstrapMissing() && ownsMetadata()) || admin(); allow update: if admin(); allow delete: if false; }
    match /roles/{id} { allow read: if active(); allow write: if admin(); }
    match /permissions/{id} { allow read, write: if admin(); }
    match /invoices/{id} { allow read: if has('invoices','view'); allow create: if active() && ownsMetadata(); allow update: if has('invoices','edit') || has('invoices','void'); allow delete: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
